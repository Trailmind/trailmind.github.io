{
    "name": "Orthogonal Thoughts by Trailmind",
    "image": "mcr.microsoft.com/devcontainers/ruby:3.3",
    "features": {
        // Essential for Antigravity's agent to use basic Linux tools
        "ghcr.io/devcontainers/features/common-utils:1": {
            "configureZshAsDefaultShell": true
        },
        "ghcr.io/devcontainers/features/github-cli:1": {}
    },
    "customizations": {
        "antigravity": {
            "settings": {
                // Fixes Mac-to-Linux line ending and terminal issues
                "terminal.integrated.defaultProfile.linux": "zsh"
            }
        },
        "vscode": {
            "extensions": [
                "mhutchie.git-graph"
            ]
        }
    },
    // Mac Performance Trick: Use a named volume for the gems
    "mounts": [
        "source=jekyll-gems,target=/usr/local/bundle,type=volume"
    ],
    "forwardPorts": [
        4000,
        35729
    ],
    "postCreateCommand": "bash .devcontainer/post-create.sh"
}